@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mi Cuenta — La Estancia Gourmet</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
            :root {
                --crema: #FAF8F3;
                --carbon: #2C2C2C;
                --dorado: #C9A84C;
                --vino: #6B2D2D;
                --gris-suave: #EDEBE5;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'Lato', sans-serif;
                background-color: var(--gris-suave);
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            /* ── NAVBAR ── */
            .navbar-estancia {
                background-color: var(--crema);
                border-bottom: 1px solid #ddd;
                padding: 1.2rem 3rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
            }

            .navbar-logo {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.4rem;
                font-weight: 400;
                color: var(--carbon);
                text-decoration: none;
            }

            .navbar-links {
                display: flex;
                gap: 2rem;
                list-style: none;
                margin: 0;
            }

                .navbar-links a {
                    font-family: 'Lato', sans-serif;
                    font-size: 0.72rem;
                    letter-spacing: 0.12em;
                    text-transform: uppercase;
                    color: var(--carbon);
                    text-decoration: none;
                    transition: color 0.25s;
                }

                    .navbar-links a:hover {
                        color: var(--dorado);
                    }

            .btn-cerrar-sesion {
                font-family: 'Lato', sans-serif;
                font-size: 0.72rem;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: #fff;
                background-color: var(--carbon);
                border: none;
                border-radius: 50px;
                padding: 0.45rem 1.2rem;
                text-decoration: none;
                transition: background 0.25s;
                cursor: pointer;
            }

                .btn-cerrar-sesion:hover {
                    background-color: var(--vino);
                    color: #fff;
                }

            /* ── CONTENIDO ── */
            .page-wrapper {
                flex: 1;
                display: flex;
                align-items: flex-start;
                justify-content: center;
                padding: 3rem 1.5rem;
            }

            .card-cuenta {
                background-color: var(--crema);
                border: 1px solid #e0dbd0;
                border-radius: 4px;
                width: 100%;
                max-width: 700px;
                overflow: hidden;
            }

            /* ── HEADER PERFIL ── */
            .perfil-header {
                background: linear-gradient(135deg, var(--carbon) 0%, #444 100%);
                padding: 2.5rem 2.5rem 1.5rem;
                display: flex;
                align-items: center;
                gap: 1.8rem;
            }

            .perfil-foto-wrapper {
                position: relative;
                cursor: pointer;
            }

            .perfil-foto {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid rgba(255,255,255,0.3);
            }

            .perfil-foto-edit {
                position: absolute;
                bottom: 0;
                right: 0;
                width: 24px;
                height: 24px;
                background-color: var(--dorado);
                border-radius: 50%;
                display: none;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                color: #fff;
            }

            .perfil-foto-wrapper:hover .perfil-foto-edit {
                display: flex;
            }

            .perfil-info {
                flex: 1;
            }

            .perfil-nombre {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.8rem;
                font-weight: 400;
                color: #fff;
                margin-bottom: 0.2rem;
            }

            .perfil-tag {
                font-family: 'Lato', sans-serif;
                font-size: 0.65rem;
                letter-spacing: 0.18em;
                text-transform: uppercase;
                color: var(--dorado);
            }

            /* ── CUERPO ── */
            .perfil-body {
                padding: 2.5rem;
            }

            .seccion-titulo {
                font-family: 'Lato', sans-serif;
                font-size: 0.65rem;
                letter-spacing: 0.2em;
                text-transform: uppercase;
                color: #aaa;
                margin-bottom: 1.5rem;
                padding-bottom: 0.5rem;
                border-bottom: 1px solid #e0dbd0;
            }

            .datos-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 1.8rem;
                margin-bottom: 2.5rem;
            }

            .dato-item {
            }

            .dato-label {
                font-family: 'Lato', sans-serif;
                font-size: 0.65rem;
                letter-spacing: 0.14em;
                text-transform: uppercase;
                color: #aaa;
                display: block;
                margin-bottom: 5px;
            }

            .dato-valor {
                font-family: 'Lato', sans-serif;
                font-size: 0.95rem;
                color: var(--carbon);
                border-bottom: 1px solid #e0dbd0;
                padding-bottom: 6px;
                display: block;
            }

            .dato-input {
                width: 100%;
                border: none;
                border-bottom: 1px solid #ccc;
                background: transparent;
                padding: 0.3rem 0;
                font-family: 'Lato', sans-serif;
                font-size: 0.95rem;
                color: var(--carbon);
                outline: none;
                transition: border-color 0.25s;
                display: none;
            }

                .dato-input:focus {
                    border-bottom-color: var(--carbon);
                }

            /* ── ACCIONES ── */
            .perfil-acciones {
                display: flex;
                gap: 1rem;
                align-items: center;
            }

            .btn-editar {
                font-family: 'Lato', sans-serif;
                font-size: 0.7rem;
                letter-spacing: 0.14em;
                text-transform: uppercase;
                color: var(--carbon);
                border: 1px solid var(--carbon);
                border-radius: 50px;
                padding: 0.55rem 1.5rem;
                background: transparent;
                cursor: pointer;
                transition: background 0.25s, color 0.25s;
            }

                .btn-editar:hover {
                    background-color: var(--carbon);
                    color: #fff;
                }

            .btn-guardar {
                font-family: 'Lato', sans-serif;
                font-size: 0.7rem;
                letter-spacing: 0.14em;
                text-transform: uppercase;
                color: #fff;
                background-color: var(--carbon);
                border: none;
                border-radius: 50px;
                padding: 0.55rem 1.5rem;
                cursor: pointer;
                transition: background 0.25s;
                display: none;
            }

                .btn-guardar:hover {
                    background-color: #444;
                }

            .btn-cancelar {
                font-family: 'Lato', sans-serif;
                font-size: 0.7rem;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: #888;
                background: transparent;
                border: none;
                cursor: pointer;
                display: none;
            }

                .btn-cancelar:hover {
                    color: var(--vino);
                }

            .alerta-ok {
                background-color: #f0fdf4;
                border-left: 3px solid #4caf50;
                padding: 0.7rem 1rem;
                margin-bottom: 1.5rem;
                border-radius: 2px;
                display: none;
            }

                .alerta-ok p {
                    font-family: 'Lato', sans-serif;
                    font-size: 0.82rem;
                    color: #2e7d32;
                    margin: 0;
                }

            .alerta-error {
                background-color: #fdf0f0;
                border-left: 3px solid var(--vino);
                padding: 0.7rem 1rem;
                margin-bottom: 1.5rem;
                border-radius: 2px;
                display: none;
            }

                .alerta-error p {
                    font-family: 'Lato', sans-serif;
                    font-size: 0.82rem;
                    color: var(--vino);
                    margin: 0;
                }

            /* ── FOOTER ── */
            footer {
                background-color: #1a1a1a;
                padding: 1.2rem 3rem;
                display: flex;
                justify-content: space-between;
            }

                footer p {
                    font-family: 'Lato', sans-serif;
                    font-size: 0.72rem;
                    color: #555;
                    margin: 0;
                }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar-estancia">
        <a href="/Cliente/Index" class="navbar-logo">La Estancia Gourmet</a>
        <ul class="navbar-links">
            <li><a href="/Cliente/Index">Inicio</a></li>
            <li><a href="/Reserva/Index">Reservas</a></li>
        </ul>
        <a href="/Cliente/CerrarSesion" class="btn-cerrar-sesion">Cerrar sesión</a>
    </nav>

    <!-- CONTENIDO -->
    <div class="page-wrapper">
        <div class="card-cuenta">

            <!-- Header -->
            <div class="perfil-header">
                <div class="perfil-foto-wrapper" onclick="document.getElementById('inputFoto').click()">
                    <img id="fotoDisplay" src="" alt="Foto de perfil" class="perfil-foto" />
                    <div class="perfil-foto-edit">✎</div>
                    <input type="file" id="inputFoto" accept="image/*" style="display:none" onchange="cambiarFoto(this)" />
                </div>
                <div class="perfil-info">
                    <p class="perfil-nombre" id="headerNombre">Cargando...</p>
                </div>
            </div>

            <!-- Cuerpo -->
            <div class="perfil-body">

                <div class="alerta-ok" id="alerta-ok"><p>Datos actualizados correctamente.</p></div>
                <div class="alerta-error" id="alerta-error"><p id="msg-error"></p></div>

                <p class="seccion-titulo">Información personal</p>

                <div class="datos-grid">
                    <div class="dato-item">
                        <span class="dato-label">Nombres</span>
                        <span class="dato-valor" id="v-Nombres"></span>
                        <input type="text" class="dato-input" id="i-Nombres" />
                    </div>
                    <div class="dato-item">
                        <span class="dato-label">Apellidos</span>
                        <span class="dato-valor" id="v-Apellidos"></span>
                        <input type="text" class="dato-input" id="i-Apellidos" />
                    </div>
                    <div class="dato-item">
                        <span class="dato-label">Documento</span>
                        <span class="dato-valor" id="v-Documento"></span>
                        <input type="text" class="dato-input" id="i-Documento" />
                    </div>
                    <div class="dato-item">
                        <span class="dato-label">Teléfono</span>
                        <span class="dato-valor" id="v-Telefono"></span>
                        <input type="text" class="dato-input" id="i-Telefono" />
                    </div>
                    <div class="dato-item" style="grid-column: span 2;">
                        <span class="dato-label">Correo electrónico</span>
                        <span class="dato-valor" id="v-Email"></span>
                        <input type="email" class="dato-input" id="i-Email" />
                    </div>
                </div>

                <div class="perfil-acciones">
                    <button class="btn-editar" id="btnEditar" onclick="activarEdicion()">Editar perfil</button>
                    <button class="btn-guardar" id="btnGuardar" onclick="guardar()">Guardar cambios</button>
                    <button class="btn-cancelar" id="btnCancelar" onclick="cancelarEdicion()">Cancelar</button>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <p>© 2026 La Estancia Gourmet</p>
        <p>RUC: 20509076945 — La Estancia S.A.C.</p>
    </footer>

    <script>
            let clienteActual = null;

            window.onload = function () {
                fetch('/Cliente/ObtenerSesion', { method: 'POST' })
                    .then(r => r.json())
                    .then(data => {
                        clienteActual = data;
                        cargarDatos(data);
                    });
            };

            function cargarDatos(data) {
                document.getElementById('headerNombre').textContent = data.nombres + ' ' + data.apellidos;
                document.getElementById('fotoDisplay').src = data.fotografia ? '/' + data.fotografia : 'https://via.placeholder.com/80';

                document.getElementById('v-Nombres').textContent = data.nombres;
                document.getElementById('v-Apellidos').textContent = data.apellidos;
                document.getElementById('v-Documento').textContent = data.documento;
                document.getElementById('v-Telefono').textContent = data.telefono;
                document.getElementById('v-Email').textContent = data.email;

                document.getElementById('i-Nombres').value = data.nombres;
                document.getElementById('i-Apellidos').value = data.apellidos;
                document.getElementById('i-Documento').value = data.documento;
                document.getElementById('i-Telefono').value = data.telefono;
                document.getElementById('i-Email').value = data.email;
            }

            function activarEdicion() {
                ['Nombres','Apellidos','Documento','Telefono','Email'].forEach(campo => {
                    document.getElementById('v-' + campo).style.display = 'none';
                    document.getElementById('i-' + campo).style.display = 'block';
                });
                document.getElementById('btnEditar').style.display = 'none';
                document.getElementById('btnGuardar').style.display = 'inline-block';
                document.getElementById('btnCancelar').style.display = 'inline-block';
                document.querySelector('.perfil-foto-edit').style.display = 'flex';
            }

            function cancelarEdicion() {
                cargarDatos(clienteActual);
                ['Nombres','Apellidos','Documento','Telefono','Email'].forEach(campo => {
                    document.getElementById('v-' + campo).style.display = 'block';
                    document.getElementById('i-' + campo).style.display = 'none';
                });
                document.getElementById('btnEditar').style.display = 'inline-block';
                document.getElementById('btnGuardar').style.display = 'none';
                document.getElementById('btnCancelar').style.display = 'none';
                document.querySelector('.perfil-foto-edit').style.display = 'none';
            }

            function cambiarFoto(input) {
                if (input.files && input.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        document.getElementById('fotoDisplay').src = e.target.result;
                    };
                    reader.readAsDataURL(input.files[0]);
                }
            }

            function guardar() {
                const formData = new FormData();
                formData.append('IdCliente', clienteActual.idCliente);
                formData.append('Nombres', document.getElementById('i-Nombres').value.trim());
                formData.append('Apellidos', document.getElementById('i-Apellidos').value.trim());
                formData.append('Documento', document.getElementById('i-Documento').value.trim());
                formData.append('Telefono', document.getElementById('i-Telefono').value.trim());
                formData.append('Email', document.getElementById('i-Email').value.trim());
                formData.append('FotoActual', clienteActual.fotografia ?? '');

                const foto = document.getElementById('inputFoto').files[0];
                if (foto) formData.append('Fotografia', foto);

                fetch('/Cliente/GestionarCliente', { method: 'POST', body: formData })
                    .then(r => r.json())
                    .then(data => {
                        if (data.resultado) {
                            document.getElementById('alerta-ok').style.display = 'block';
                            document.getElementById('alerta-error').style.display = 'none';
                            cancelarEdicion();
                            // Recargar datos actualizados
                            fetch('/Cliente/ObtenerSesion', { method: 'POST' })
                                .then(r => r.json())
                                .then(d => { clienteActual = d; cargarDatos(d); });
                        } else {
                            document.getElementById('alerta-error').style.display = 'block';
                            document.getElementById('msg-error').textContent = data.mensaje;
                        }
                    });
            }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
