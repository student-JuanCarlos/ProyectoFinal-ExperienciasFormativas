        <div class="modal-sub" id="cancelarSub" style="font-size:13px; color:#6B7280; margin-bottom:1.4rem; line-height:1.5;"></div>
        <div style="background:rgba(239,68,68,0.06); border-left:3px solid var(--rojo); padding:0.6rem 0.9rem; border-radius:4px; font-size:12px; color:#dc2626; margin-bottom:1.2rem;">
            <i class="bi bi-exclamation-triangle"></i>
            Esta acción no se puede deshacer. Las mesas quedarán libres.
        </div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="cerrarConfirmarCancelar()">Volver</button>
            <button class="btn-rojo" onclick="ejecutarCancelar()">
                <i class="bi bi-x-circle"></i> Cancelar reserva
            </button>
        </div>
    </div>
</div>

<script>
    const mesasData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
        mesasData ?? new List<App_Web.Models.VM.MesaVM>(),
        new Newtonsoft.Json.JsonSerializerSettings {
            ContractResolver = new Newtonsoft.Json.Serialization.CamelCasePropertyNamesContractResolver()
        }
    ));

    let posiciones = {};
    try {
        const saved = localStorage.getItem('salon_posiciones');
        if (saved) posiciones = JSON.parse(saved);
    } catch(e) {}

    let mesasSeleccionadasNueva = [];
    let mesasSeleccionadasMesas = [];
    let reservaDetalleActual    = null;
    let cancelarIdPendiente     = null;
    let cancelarMesasPendientes = [];

    function colorBorde(estado) {
        if (estado === 1) return '#16a34a';
        if (estado === 2) return '#b45309';
        if (estado === 3) return '#dc2626';
        return '#9CA3AF';
    }
    function colorSilla(estado) {
        if (estado === 1) return '#28FC64';
        if (estado === 2) return '#FFDD00';
        if (estado === 3) return '#FC4C28';
        return '#B4B2A9';
    }
    function mesaSize(p) {
        if (p <= 2) return { w: 60,  h: 34 };
        if (p <= 4) return { w: 80,  h: 44 };
        if (p <= 6) return { w: 100, h: 54 };
        if (p <= 8) return { w: 120, h: 62 };
        return              { w: 145, h: 70 };
    }
    function crearSVG(m, vertical, seleccionada) {
        const { w, h } = mesaSize(m.espacioOcupable);
        const CH = 9, CG = 4;
        const cols = Math.ceil(m.espacioOcupable / 2);
        const cw   = Math.max(10, Math.floor(w / (cols + 1)) - 3);
        const sp   = w / (cols + 1);
        const ox   = CG, oy = CH + CG;
        const totalW = w + CG * 2;
        const totalH = h + (CH + CG) * 2;
        const borde  = seleccionada ? '#C9A84C' : colorBorde(m.estado);
        const silla  = seleccionada ? '#C9A84C' : colorSilla(m.estado);
        const fill   = seleccionada ? 'rgba(201,168,76,0.1)' : 'white';

        let chairs = '';
        for (let i = 0; i < cols; i++) {
            const cx = ox + sp * (i + 1) - cw / 2;
            chairs += `<rect x="${cx.toFixed(1)}" y="${oy-CH-3}" width="${cw}" height="${CH}" rx="2" fill="${silla}" opacity="0.85"/>`;
            if (i * 2 + 1 < m.espacioOcupable)
                chairs += `<rect x="${cx.toFixed(1)}" y="${oy+h+3}" width="${cw}" height="${CH}" rx="2" fill="${silla}" opacity="0.85"/>`;
        }
        const svgW = vertical ? totalH : totalW;
        const svgH = vertical ? totalW : totalH;
        const transform = vertical ? `rotate(90) translate(0, -${totalW})` : '';
        return `<svg width="${svgW}" height="${svgH}" xmlns="http://www.w3.org/2000/svg" style="overflow:visible;">
            <g transform="${transform}">
                ${chairs}
                <rect x="${ox}" y="${oy}" width="${w}" height="${h}" rx="5"
                    fill="${fill}" stroke="${borde}" stroke-width="${seleccionada ? 2.5 : 2}"/>
                <text x="${ox+w/2}" y="${oy+h/2+4}" text-anchor="middle"
                    font-family="Lato,sans-serif" font-size="13" font-weight="700" fill="#2C2C2C">${m.numeroMesa}</text>
                <text x="${ox+w/2}" y="${oy+h/2+17}" text-anchor="middle"
                    font-family="Lato,sans-serif" font-size="10" fill="#9CA3AF">${m.espacioOcupable}p</text>
            </g>
        </svg>`;
    }

    function renderSalonModal(contenedorId, seleccionadas, onClickMesa) {
        const salon = document.getElementById(contenedorId);
        salon.innerHTML = '';

        const inner = document.createElement('div');
        inner.style.cssText = 'position:relative; width:1200px; height:800px;';

        let autoX = 20, autoY = 20;

        mesasData.forEach(m => {
            const { w, h } = mesaSize(m.espacioOcupable);
            const CG = 4, CH = 9;
            const totalW = w + CG * 2;
            const totalH = h + (CH + CG) * 2;
            const pos = posiciones[m.idMesa] || { x: autoX, y: autoY, vertical: false };
            if (!posiciones[m.idMesa]) {
                autoX += totalW + 20;
                if (autoX + totalW > 1100) { autoX = 20; autoY += totalH + 20; }
            }

            const sel = seleccionadas.includes(m.idMesa);
            const div = document.createElement('div');
            div.style.cssText = `position:absolute; left:${pos.x}px; top:${pos.y}px; user-select:none;`;

            const clickeable = m.estado === 1 || sel;
            div.style.cursor  = clickeable ? 'pointer' : 'not-allowed';
            div.style.opacity = m.estado !== 1 && !sel ? '0.5' : '1';
            div.innerHTML = crearSVG(m, pos.vertical || false, sel);

            if (clickeable) {
                div.addEventListener('click', () => onClickMesa(m, div, seleccionadas, contenedorId));
            }
            inner.appendChild(div);
        });

        salon.appendChild(inner);
    }

    function toggleMesaNueva(m, div, seleccionadas, contenedorId) {
        const idx = seleccionadas.indexOf(m.idMesa);
        if (idx === -1) seleccionadas.push(m.idMesa);
        else            seleccionadas.splice(idx, 1);
        div.innerHTML = crearSVG(m, posiciones[m.idMesa]?.vertical || false, seleccionadas.includes(m.idMesa));
        actualizarBadgesMesas(seleccionadas, contenedorId === 'salonModal' ? 'mesasSeleccionadas' : 'mesasSeleccionadasMesas');
        actualizarCapacidad(seleccionadas, contenedorId === 'salonModal' ? 'capacidadSeleccionada' : 'capacidadMesas');
        validarCapacidad();
    }

    function actualizarBadgesMesas(seleccionadas, contenedorId) {
        const wrap = document.getElementById(contenedorId);
        wrap.innerHTML = '';
        seleccionadas.forEach(id => {
            const mesa = mesasData.find(m => m.idMesa === id);
            if (!mesa) return;
            const badge = document.createElement('div');
            badge.className = 'badge-mesa-sel';
            badge.innerHTML = `Mesa ${mesa.numeroMesa} <button onclick="quitarMesa(${id}, '${contenedorId}')">×</button>`;
            wrap.appendChild(badge);
        });
    }

    function quitarMesa(idMesa, contenedorId) {
        const lista = contenedorId === 'mesasSeleccionadas' ? mesasSeleccionadasNueva : mesasSeleccionadasMesas;
        const idx = lista.indexOf(idMesa);
        if (idx !== -1) lista.splice(idx, 1);
        renderSalonModal(contenedorId === 'mesasSeleccionadas' ? 'salonModal' : 'salonModalMesas',
                         lista, toggleMesaNueva);
        actualizarBadgesMesas(lista, contenedorId);
        actualizarCapacidad(lista, contenedorId === 'mesasSeleccionadas' ? 'capacidadSeleccionada' : 'capacidadMesas');
        validarCapacidad();
    }

    function actualizarCapacidad(seleccionadas, spanId) {
        const total = seleccionadas.reduce((sum, id) => {
            const m = mesasData.find(x => x.idMesa === id);
            return sum + (m ? m.espacioOcupable : 0);
        }, 0);
        document.getElementById(spanId).textContent = total;
        return total;
    }

    function getCapacidadTotal(seleccionadas) {
        return seleccionadas.reduce((sum, id) => {
            const m = mesasData.find(x => x.idMesa === id);
            return sum + (m ? m.espacioOcupable : 0);
        }, 0);
    }

    function validarCapacidad() {
        const personas   = parseInt(document.getElementById('nPersonas')?.value) || 0;
        const capacidad  = getCapacidadTotal(mesasSeleccionadasNueva);
        const aviso      = document.getElementById('avisoCapacidad');
        if (!aviso) return;

        if (personas > 0 && capacidad > 0) {
            if (capacidad < personas) {
                aviso.textContent    = `⚠ Espacio insuficiente — tienes ${capacidad} lugares para ${personas} personas. Selecciona más mesas.`;
                aviso.style.display  = 'block';
            } else if (capacidad > personas * 1.5 && personas > 0) {
                aviso.textContent    = `ℹ Estás usando más espacio del necesario (${capacidad} lugares para ${personas} personas). Considera usar menos mesas.`;
                aviso.style.display  = 'block';
            } else {
                aviso.style.display  = 'none';
            }
        } else {
            aviso.style.display = 'none';
        }
    }

    function abrirModalNueva() {
        mesasSeleccionadasNueva = [];
        document.getElementById('nNombre').value   = '';
        document.getElementById('nTelefono').value = '';
        document.getElementById('nPersonas').value = '';
        document.getElementById('alertaNueva').style.display    = 'none';
        document.getElementById('avisoCapacidad').style.display = 'none';
        document.getElementById('mesasSeleccionadas').innerHTML = '';
        document.getElementById('capacidadSeleccionada').textContent = '0';
        renderSalonModal('salonModal', mesasSeleccionadasNueva, toggleMesaNueva);
        document.getElementById('modalNueva').classList.add('show');
    }

    function cerrarModalNueva() { document.getElementById('modalNueva').classList.remove('show'); }

    function guardarReserva() {
        const alerta   = document.getElementById('alertaNueva');
        const nombre   = document.getElementById('nNombre').value.trim();
        const personas = parseInt(document.getElementById('nPersonas').value) || 0;
        const capacidad = getCapacidadTotal(mesasSeleccionadasNueva);

        if (!nombre) {
            alerta.textContent = 'El nombre del cliente es obligatorio.';
            alerta.style.display = 'block'; return;
        }
        if (personas <= 0) {
            alerta.textContent = 'Ingresa la cantidad de personas.';
            alerta.style.display = 'block'; return;
        }
        if (mesasSeleccionadasNueva.length === 0) {
            alerta.textContent = 'Selecciona al menos una mesa.';
            alerta.style.display = 'block'; return;
        }
        if (capacidad < personas) {
            alerta.textContent = `Espacio insuficiente — ${capacidad} lugares para ${personas} personas.`;
            alerta.style.display = 'block'; return;
        }

        const payload = {
            Reserva: {
                NombreCliente:    nombre,
                TelefonoCliente:  document.getElementById('nTelefono').value.trim() || null,
                CantidadPersonas: personas
            },
            DetalleReserva: mesasSeleccionadasNueva.map(id => ({ IdMesa: id }))
        };

        fetch('/Reserva/InsertarReserva', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        }).then(() => location.reload());
    }

    function abrirModalEditar(id, nombre, telefono, personas) {
        document.getElementById('eIdReserva').value = id;
        document.getElementById('eNombre').value    = nombre || '';
        document.getElementById('eTelefono').value  = telefono || '';
        document.getElementById('ePersonas').value  = personas;
        document.getElementById('alertaEditar').style.display = 'none';
        document.getElementById('avisoCapacidadEditar').style.display = 'none';
        document.getElementById('modalEditar').classList.add('show');
    }

    function cerrarModalEditar() { document.getElementById('modalEditar').classList.remove('show'); }

    function guardarEdicion() {
        const alerta  = document.getElementById('alertaEditar');
        const personas = parseInt(document.getElementById('ePersonas').value) || 0;
        if (personas <= 0) {
            alerta.textContent = 'Ingresa la cantidad de personas.';
            alerta.style.display = 'block'; return;
        }
        document.getElementById('formEditar').submit();
    }

    function abrirModalMesas(idReserva, personas) {
        mesasSeleccionadasMesas = [];
        document.getElementById('alertaMesas').style.display              = 'none';
        document.getElementById('avisoCapacidadMesas').style.display      = 'none';
        document.getElementById('mesasSeleccionadasMesas').innerHTML      = '';
        document.getElementById('capacidadMesas').textContent             = '0';
        document.getElementById('modalMesas').dataset.idReserva           = idReserva;
        document.getElementById('modalMesas').dataset.personas            = personas;
        renderSalonModal('salonModalMesas', mesasSeleccionadasMesas, (m, div, sel, cont) => {
            toggleMesaNueva(m, div, mesasSeleccionadasMesas, cont);
            const cap     = getCapacidadTotal(mesasSeleccionadasMesas);
            const pers    = parseInt(document.getElementById('modalMesas').dataset.personas) || 0;
            const avisoM  = document.getElementById('avisoCapacidadMesas');
            if (cap > 0 && pers > 0) {
                if (cap < pers) {
                    avisoM.textContent   = `⚠ Espacio insuficiente — ${cap} lugares para ${pers} personas.`;
                    avisoM.style.display = 'block';
                } else if (cap > pers * 1.5) {
                    avisoM.textContent   = `ℹ Estás usando más espacio del necesario (${cap} lugares para ${pers} personas).`;
                    avisoM.style.display = 'block';
                } else {
                    avisoM.style.display = 'none';
                }
            }
        });
        cerrarDetalle();
        document.getElementById('modalMesas').classList.add('show');
    }

    function cerrarModalMesas() { document.getElementById('modalMesas').classList.remove('show'); }

    function guardarMesas() {
        const alerta   = document.getElementById('alertaMesas');
        const idReserva = parseInt(document.getElementById('modalMesas').dataset.idReserva);
        const personas  = parseInt(document.getElementById('modalMesas').dataset.personas) || 0;
        const capacidad = getCapacidadTotal(mesasSeleccionadasMesas);

        if (mesasSeleccionadasMesas.length === 0) {
            alerta.textContent = 'Selecciona al menos una mesa.';
            alerta.style.display = 'block'; return;
        }
        if (capacidad < personas) {
            alerta.textContent = `Espacio insuficiente — ${capacidad} lugares para ${personas} personas.`;
            alerta.style.display = 'block'; return;
        }

        fetch('/Reserva/ActualizarMesas', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ IdReserva: idReserva, Mesas: mesasSeleccionadasMesas })
        }).then(() => location.reload());
    }

    function abrirDetalle(id) {
        fetch(`/Reserva/Detalle?id=${id}`)
            .then(r => r.json())
            .then(d => {
                if (!d) return;
                reservaDetalleActual = d;

                const secCliente = document.getElementById('seccionCliente');
                if (d.cliente && d.cliente.nombres) {
                    secCliente.style.display = 'block';
                    document.getElementById('dClienteNombre').textContent = d.cliente.nombres;
                    document.getElementById('dClienteDoc').textContent    = d.cliente.documento ?? '—';
                    document.getElementById('dClienteTel').textContent    = d.cliente.telefono ?? '—';
                    document.getElementById('dClienteEmail').textContent  = d.cliente.email ?? '—';

                    const fotoWrap = document.getElementById('clienteFoto');
                    if (d.cliente.fotoActual) {
                        fotoWrap.innerHTML = `<img src="/${d.cliente.fotoActual}" class="cliente-foto" alt="foto" />`;
                    } else {
                        const iniciales = d.cliente.nombres.split(' ').slice(0,2).map(p => p[0]).join('').toUpperCase();
                        fotoWrap.innerHTML = `<div class="cliente-foto-placeholder">${iniciales}</div>`;
                    }
                } else {
                    secCliente.style.display = 'none';
                }

                document.getElementById('dGeneradoPor').textContent = d.usuario?.nombreUsuario ?? d.cliente?.nombres ?? '—';
                document.getElementById('dTipo').textContent        = d.tipoReserva;
                const fecha = new Date(d.fechaReserva);
                document.getElementById('dFecha').textContent = fecha.toLocaleDateString('es-PE', { day:'2-digit', month:'2-digit', year:'numeric' });
                document.getElementById('dHora').textContent   = d.horaReserva ?? '—';
                document.getElementById('dPersonas').textContent = d.cantidadPersonas + ' personas';
                document.getElementById('dCosto').textContent   = 'S/ ' + parseFloat(d.costoTotal).toFixed(2);

                const mesasWrap = document.getElementById('dMesas');
                mesasWrap.innerHTML = '';
                if (d.detalleMesa && d.detalleMesa.length > 0) {
                    d.detalleMesa.forEach(dr => {
                        const b = document.createElement('span');
                        b.className = 'badge-mesa-det';
                        b.textContent = 'Mesa ' + dr.mesa.numeroMesa;
                        mesasWrap.appendChild(b);
                    });
                } else {
                    mesasWrap.innerHTML = '<span style="font-size:12px;color:#9CA3AF;">Sin mesas asignadas</span>';
                }

                const acciones = document.getElementById('detalleAcciones');
                acciones.innerHTML = '<button class="btn-cancel" onclick="cerrarDetalle()">Cerrar</button>';
                if (d.estado === 1) {
                    const mesaIds = d.detalleMesa?.map(dr => dr.idMesa) ?? [];
                    acciones.innerHTML += `
                        <button class="btn-accion btn-accion-edit"
                            onclick="cerrarDetalle(); abrirModalEditar(${d.idReserva}, '${d.nombreCliente ?? ''}', '${d.telefonoCliente ?? ''}', ${d.cantidadPersonas})">
                            <i class="bi bi-pencil"></i> Editar
                        </button>
                        <button class="btn-accion btn-accion-mesas"
                            onclick="abrirModalMesas(${d.idReserva}, ${d.cantidadPersonas})">
                            <i class="bi bi-grid-1x2"></i> Cambiar mesas
                        </button>
                        <button class="btn-accion btn-accion-cancel"
                            onclick="cerrarDetalle(); confirmarCancelar(${d.idReserva}, '${d.nombreCliente ?? d.usuario?.nombreUsuario ?? ''}')">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>`;
                }

                document.getElementById('modalDetalle').classList.add('show');
            });
    }

    function cerrarDetalle() { document.getElementById('modalDetalle').classList.remove('show'); }

    function confirmarCancelar(id, nombre) {
        cancelarIdPendiente = id;
        fetch(`/Reserva/Detalle?id=${id}`)
            .then(r => r.json())
            .then(d => {
                cancelarMesasPendientes = d.detalleMesa?.map(dr => dr.idMesa) ?? [];
                document.getElementById('cancelarSub').textContent =
                    `¿Estás seguro de cancelar la reserva de "${nombre}"?`;
                document.getElementById('modalConfirmarCancelar').classList.add('show');
            });
    }

    function cerrarConfirmarCancelar() {
        document.getElementById('modalConfirmarCancelar').classList.remove('show');
        cancelarIdPendiente     = null;
        cancelarMesasPendientes = [];
    }

    function ejecutarCancelar() {
        if (!cancelarIdPendiente) return;
        fetch('/Reserva/CancelarReserva', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ IdReserva: cancelarIdPendiente, Mesas: cancelarMesasPendientes })
        }).then(() => location.reload());
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
