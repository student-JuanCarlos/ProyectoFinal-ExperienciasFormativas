@model IEnumerable<App_Web.Models.VM.ReservaVM>
@{
    Layout = null;
    int paginas      = ViewBag.Paginas ?? 1;
    int paginaActual = ViewBag.PaginaActual ?? 1;
    string busqueda  = Context.Request.Query["Busqueda"];
    string estadoQ   = Context.Request.Query["Estado"];

    // Datos del salon para el gráfico
    var mesasData = ViewBag.Mesas as List<App_Web.Models.VM.MesaVM>;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --sidebar-bg: #1C1C1C;
            --acento:     #C9A84C;
            --fondo:      #F4F5F7;
            --card:       #ffffff;
            --carbon:     #2C2C2C;
            --borde:      #E5E7EB;
            --rojo:       #EF4444;
            --verde:      #22C55E;
            --azul:       #3B82F6;
            --amarillo:   #F59E0B;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Lato', sans-serif;
            background: var(--fondo);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            width: 220px; background: var(--sidebar-bg);
            display: flex; flex-direction: column;
            flex-shrink: 0; height: 100vh;
        }
        .sidebar-header {
            padding: 1.4rem 1.2rem 1.2rem;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }
        .sidebar-logo { font-size: 14px; font-weight: 700; color: var(--acento); }
        .sidebar-sub  { font-size: 10px; color: rgba(255,255,255,0.3); letter-spacing: 0.14em; text-transform: uppercase; margin-top: 2px; }
        .sidebar-nav  { flex: 1; padding: 0.8rem 0; }
        .nav-item {
            display: flex; align-items: center; gap: 10px;
            padding: 0.6rem 1.2rem; font-size: 13px;
            color: rgba(255,255,255,0.45); text-decoration: none;
            border-left: 2px solid transparent; transition: all 0.2s;
        }
        .nav-item:hover  { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.85); }
        .nav-item.active { background: rgba(201,168,76,0.12); color: #fff; border-left-color: var(--acento); }
        .nav-item i { font-size: 15px; }
        .sidebar-footer {
            padding: 1rem 1.2rem;
            border-top: 1px solid rgba(255,255,255,0.07);
            display: flex; align-items: center; gap: 10px;
        }
        .avatar {
            width: 30px; height: 30px; border-radius: 50%;
            background: var(--acento);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; color: var(--sidebar-bg);
        }
        .sidebar-user-name { font-size: 12px; color: #fff; }
        .sidebar-user-role { font-size: 11px; color: rgba(255,255,255,0.35); }

        /* MAIN */
        .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .topbar {
            background: var(--card); border-bottom: 1px solid var(--borde);
            padding: 0.9rem 1.8rem;
            display: flex; justify-content: space-between; align-items: center;
        }
        .topbar-titulo { font-size: 16px; font-weight: 700; color: var(--carbon); }
        .topbar-sub    { font-size: 12px; color: #9CA3AF; }
        .content { flex: 1; overflow-y: auto; padding: 1.5rem 1.8rem; }

        /* TOOLBAR */
        .toolbar {
            background: var(--card); border: 1px solid var(--borde);
            border-radius: 10px; padding: 0.9rem 1.2rem;
            display: flex; justify-content: space-between; align-items: center;
            gap: 1rem; margin-bottom: 1.2rem; flex-wrap: wrap;
        }
        .toolbar-filtros { display: flex; gap: 0.6rem; align-items: center; flex-wrap: wrap; }
        .input-filtro {
            border: 1px solid var(--borde); border-radius: 6px;
            padding: 0.4rem 0.8rem; font-size: 13px;
            font-family: 'Lato', sans-serif; outline: none;
            width: 190px; transition: border-color 0.2s;
        }
        .input-filtro:focus { border-color: var(--carbon); }
        .select-filtro {
            border: 1px solid var(--borde); border-radius: 6px;
            padding: 0.4rem 0.8rem; font-size: 13px;
            font-family: 'Lato', sans-serif; outline: none;
            background: #fff; color: var(--carbon); cursor: pointer;
        }
        .btn-buscar {
            background: var(--carbon); color: #fff; border: none;
            border-radius: 6px; padding: 0.4rem 0.9rem; font-size: 13px;
            cursor: pointer; display: flex; align-items: center; gap: 4px;
            transition: background 0.2s;
        }
        .btn-buscar:hover { background: #444; }
        .btn-limpiar {
            background: transparent; border: 1px solid var(--borde);
            border-radius: 6px; padding: 0.4rem 0.8rem; font-size: 13px;
            color: #6B7280; text-decoration: none;
            display: flex; align-items: center; gap: 4px; transition: all 0.2s;
        }
        .btn-limpiar:hover { border-color: var(--carbon); color: var(--carbon); }
        .btn-nuevo {
            background: var(--carbon); color: #fff; border: none;
            border-radius: 6px; padding: 0.4rem 1rem; font-size: 13px;
            font-family: 'Lato', sans-serif; cursor: pointer;
            display: flex; align-items: center; gap: 5px;
            transition: background 0.2s; white-space: nowrap;
        }
        .btn-nuevo:hover { background: #444; }

        /* GRILLA */
        .grilla {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-bottom: 1.2rem;
        }

        /* CARD RESERVA */
        .reserva-card {
            background: var(--card); border: 1px solid var(--borde);
            border-radius: 12px; overflow: hidden;
            display: flex; flex-direction: column;
            transition: box-shadow 0.2s, transform 0.2s;
        }
        .reserva-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            transform: translateY(-2px);
        }

        .card-top-reserva {
            padding: 1rem 1.1rem 0.8rem;
            border-bottom: 1px solid var(--borde);
            display: flex; justify-content: space-between; align-items: flex-start;
        }
        .card-tipo-nombre { display: flex; flex-direction: column; gap: 4px; }
        .card-nombre-reserva {
            font-size: 14px; font-weight: 700; color: var(--carbon);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
            max-width: 200px;
        }
        .card-badges-top { display: flex; gap: 4px; align-items: center; }

        .badge-tipo-directa { background: rgba(59,130,246,0.1);  color: var(--azul);   font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }
        .badge-tipo-web     { background: rgba(34,197,94,0.12);  color: #16a34a;       font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }

        .badge-estado-1 { background: rgba(245,158,11,0.12); color: #92400e;  font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }
        .badge-estado-2 { background: rgba(34,197,94,0.12);  color: #16a34a;  font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }
        .badge-estado-3 { background: rgba(239,68,68,0.12);  color: #dc2626;  font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 20px; }

        .card-body-reserva {
            padding: 0.8rem 1.1rem; flex: 1;
            display: flex; flex-direction: column; gap: 6px;
        }
        .card-dato {
            display: flex; align-items: center; gap: 6px;
            font-size: 12px; color: #6B7280;
        }
        .card-dato i { font-size: 12px; color: #9CA3AF; flex-shrink: 0; }
        .card-costo {
            font-size: 16px; font-weight: 700; color: var(--acento);
            margin-top: 2px;
        }
        .card-costo span { font-size: 11px; font-weight: 400; color: #9CA3AF; }

        .card-footer-reserva {
            padding: 0.6rem 1.1rem;
            border-top: 1px solid var(--borde);
            display: flex; justify-content: space-between; align-items: center;
        }
        .btn-icono {
            width: 28px; height: 28px; border-radius: 6px; border: none;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; cursor: pointer; transition: all 0.2s;
        }
        .btn-detalle       { background: rgba(44,44,44,0.07);  color: var(--carbon); }
        .btn-detalle:hover { background: var(--carbon); color: #fff; }
        .btn-cancelar-card       { background: rgba(239,68,68,0.1);  color: var(--rojo); }
        .btn-cancelar-card:hover { background: var(--rojo); color: #fff; }

        /* VACÍO */
        .vacio {
            grid-column: 1 / -1; text-align: center;
            padding: 3rem; color: #9CA3AF; font-size: 14px;
        }
        .vacio i { font-size: 40px; display: block; margin-bottom: 0.8rem; color: #D1D5DB; }

        /* PAGINACIÓN */
        .paginacion {
            display: flex; justify-content: center; gap: 0.4rem;
            margin-bottom: 1rem;
        }
        .pag-btn {
            width: 32px; height: 32px; border-radius: 6px;
            border: 1px solid var(--borde); background: var(--card);
            color: var(--carbon); font-size: 13px;
            display: flex; align-items: center; justify-content: center;
            text-decoration: none; transition: all 0.2s;
        }
        .pag-btn:hover  { border-color: var(--carbon); color: var(--carbon); }
        .pag-btn.activo { background: var(--carbon); color: #fff; border-color: var(--carbon); }
        .pag-btn.disabled { opacity: 0.4; pointer-events: none; }

        /* MODALES */
        .modal-overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.45);
            display: none; align-items: center; justify-content: center; z-index: 1000;
        }
        .modal-overlay.show { display: flex; }
        .modal-box {
            background: var(--card); border-radius: 12px; padding: 1.8rem;
            width: 100%; max-width: 500px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
            max-height: 90vh; overflow-y: auto;
        }
        .modal-box-lg {
            background: var(--card); border-radius: 12px; padding: 1.8rem;
            width: 100%; max-width: 680px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
            max-height: 90vh; overflow-y: auto;
        }
        .modal-titulo { font-size: 15px; font-weight: 700; color: var(--carbon); margin-bottom: 1.4rem; }

        .campo-grupo { margin-bottom: 1rem; }
        .campo-label {
            font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em;
            color: #9CA3AF; display: block; margin-bottom: 5px;
        }
        .campo-input {
            width: 100%; border: 1px solid var(--borde); border-radius: 6px;
            padding: 0.5rem 0.8rem; font-family: 'Lato', sans-serif;
            font-size: 14px; color: var(--carbon); outline: none;
            transition: border-color 0.2s;
        }
        .campo-input:focus { border-color: var(--carbon); }
        .campo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }

        .alerta {
            background: #FEF2F2; border-left: 3px solid var(--rojo);
            padding: 0.6rem 0.9rem; border-radius: 4px;
            font-size: 12px; color: var(--rojo); margin-bottom: 1rem; display: none;
        }
        .aviso-info {
            background: rgba(201,168,76,0.08); border-left: 3px solid var(--acento);
            padding: 0.6rem 0.9rem; border-radius: 4px;
            font-size: 12px; color: #92400e; margin-bottom: 1rem;
            display: flex; align-items: center; gap: 6px;
        }
        .aviso-capacidad {
            background: rgba(245,158,11,0.08); border-left: 3px solid var(--amarillo);
            padding: 0.6rem 0.9rem; border-radius: 4px;
            font-size: 12px; color: #92400e; margin-bottom: 1rem; display: none;
        }

        .modal-actions { display: flex; gap: 0.6rem; justify-content: flex-end; margin-top: 1.4rem; }
        .btn-cancel {
            background: transparent; border: 1px solid var(--borde);
            border-radius: 6px; padding: 0.45rem 1.1rem; font-size: 13px;
            font-family: 'Lato', sans-serif; cursor: pointer; color: #6B7280;
        }
        .btn-save {
            background: var(--carbon); color: #fff; border: none;
            border-radius: 6px; padding: 0.45rem 1.3rem; font-size: 13px;
            font-family: 'Lato', sans-serif; cursor: pointer;
            display: flex; align-items: center; gap: 5px; transition: background 0.2s;
        }
        .btn-save:hover { background: #444; }
        .btn-save.editar { background: var(--azul); }
        .btn-save.editar:hover { background: #2563EB; }
        .btn-rojo {
            background: var(--rojo); color: #fff; border: none;
            border-radius: 6px; padding: 0.45rem 1.3rem; font-size: 13px;
            font-family: 'Lato', sans-serif; cursor: pointer;
            display: flex; align-items: center; gap: 5px; transition: background 0.2s;
        }
        .btn-rojo:hover { background: #DC2626; }

        /* GRÁFICO SALÓN EN MODAL */
        #salonModal, #salonModalMesas {
            position: relative; width: 100%; height: 420px;
            background-image: linear-gradient(rgba(0,0,0,0.04) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(0,0,0,0.04) 1px, transparent 1px);
            background-size: 28px 28px;
            border: 1px solid var(--borde); border-radius: 8px;
            overflow: auto; margin-bottom: 0.8rem;
        }
        .salon-instruccion {
            font-size: 11px; color: #9CA3AF; margin-bottom: 0.8rem;
            display: flex; align-items: center; gap: 4px;
        }
        .mesas-seleccionadas {
            display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 1rem; min-height: 28px;
        }
        .badge-mesa-sel {
            background: var(--carbon); color: #fff;
            font-size: 11px; font-weight: 600;
            padding: 3px 10px; border-radius: 20px;
            display: flex; align-items: center; gap: 4px;
        }
        .badge-mesa-sel button {
            background: none; border: none; color: #fff;
            cursor: pointer; font-size: 12px; padding: 0; line-height: 1;
        }
        .capacidad-info {
            font-size: 12px; color: #6B7280;
            display: flex; align-items: center; gap: 4px; margin-bottom: 0.8rem;
        }
        .capacidad-info span { font-weight: 700; color: var(--carbon); }

        /* DETALLE MODAL */
        .detalle-seccion {
            margin-bottom: 1.2rem;
            padding-bottom: 1.2rem;
            border-bottom: 1px solid var(--borde);
        }
        .detalle-seccion:last-child { border-bottom: none; margin-bottom: 0; }
        .detalle-seccion-titulo {
            font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em;
            color: #9CA3AF; font-weight: 700; margin-bottom: 0.8rem;
        }
        .detalle-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
        .detalle-item { display: flex; flex-direction: column; gap: 2px; }
        .detalle-lbl  { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: #9CA3AF; }
        .detalle-val  { font-size: 13px; font-weight: 600; color: var(--carbon); }

        /* Cliente en detalle */
        .cliente-header {
            display: flex; align-items: center; gap: 1rem; margin-bottom: 0.8rem;
        }
        .cliente-foto {
            width: 50px; height: 50px; border-radius: 50%;
            object-fit: cover; border: 2px solid var(--borde);
            flex-shrink: 0;
        }
        .cliente-foto-placeholder {
            width: 50px; height: 50px; border-radius: 50%;
            background: rgba(201,168,76,0.12);
            display: flex; align-items: center; justify-content: center;
            font-size: 18px; font-weight: 700; color: var(--acento);
            flex-shrink: 0; border: 2px solid var(--borde);
        }
        .cliente-nombre { font-size: 15px; font-weight: 700; color: var(--carbon); }
        .cliente-doc    { font-size: 12px; color: #9CA3AF; }

        /* Mesas en detalle */
        .mesas-detalle { display: flex; flex-wrap: wrap; gap: 4px; }
        .badge-mesa-det {
            background: rgba(44,44,44,0.07); color: var(--carbon);
            font-size: 11px; font-weight: 700;
            padding: 3px 10px; border-radius: 20px;
        }

        /* Acciones detalle */
        .detalle-acciones {
            display: flex; gap: 0.6rem; justify-content: flex-end; flex-wrap: wrap;
        }
        .btn-accion {
            border: none; border-radius: 6px; padding: 0.45rem 1rem; font-size: 12px;
            font-family: 'Lato', sans-serif; cursor: pointer;
            display: flex; align-items: center; gap: 5px; transition: background 0.2s;
        }
        .btn-accion-edit   { background: rgba(59,130,246,0.1);  color: var(--azul); }
        .btn-accion-edit:hover { background: var(--azul); color: #fff; }
        .btn-accion-mesas  { background: rgba(201,168,76,0.1);  color: #92400e; }
        .btn-accion-mesas:hover { background: var(--acento); color: #fff; }
        .btn-accion-cancel { background: rgba(239,68,68,0.1);  color: var(--rojo); }
        .btn-accion-cancel:hover { background: var(--rojo); color: #fff; }

        #formCancelar { display: none; }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo">La Estancia</div>
        <div class="sidebar-sub">Sistema interno</div>
    </div>
    <nav class="sidebar-nav">
        <a class="nav-item" href="#"><i class="bi bi-speedometer2"></i> Dashboard</a>
        <a class="nav-item" href="/Mesa/Index"><i class="bi bi-grid-1x2"></i> Mesas</a>
        <a class="nav-item active" href="/Reserva/Index"><i class="bi bi-calendar-check"></i> Reservas</a>
        <a class="nav-item" href="#"><i class="bi bi-receipt"></i> Ventas</a>
        <a class="nav-item" href="/Platillo/Index"><i class="bi bi-egg-fried"></i> Platillos</a>
        <a class="nav-item" href="/Usuario/Index"><i class="bi bi-people"></i> Usuarios</a>
        <a class="nav-item" href="/Descuento/Index"><i class="bi bi-percent"></i> Descuentos</a>
        <a class="nav-item" href="#"><i class="bi bi-gear"></i> Configuración</a>
    </nav>
    <div class="sidebar-footer">
        <div class="avatar">AD</div>
        <div>
            <div class="sidebar-user-name">Administrador</div>
            <div class="sidebar-user-role">Sistema</div>
        </div>
    </div>
</aside>

<main class="main">
    <div class="topbar">
        <div>
            <div class="topbar-titulo">Reservas</div>
            <div class="topbar-sub">Gestión de reservas del restaurante</div>
        </div>
    </div>

    <div class="content">

        <!-- TOOLBAR -->
        <div class="toolbar">
            <form method="get" action="/Reserva/Index" class="toolbar-filtros">
                <input type="text" name="Busqueda" class="input-filtro"
                       placeholder="Buscar cliente o tipo..." value="@busqueda" />
                <select name="Estado" class="select-filtro">
                    <option value="">Todos</option>
                    @if (estadoQ == "1")
                    {
                        <option value="1" selected>Pendiente</option>
                        <option value="2">Concluido</option>
                        <option value="3">Cancelado</option>
                    }
                    else if (estadoQ == "2")
                    {
                        <option value="1">Pendiente</option>
                        <option value="2" selected>Concluido</option>
                        <option value="3">Cancelado</option>
                    }
                    else if (estadoQ == "3")
                    {
                        <option value="1">Pendiente</option>
                        <option value="2">Concluido</option>
                        <option value="3" selected>Cancelado</option>
                    }
                    else
                    {
                        <option value="1">Pendiente</option>
                        <option value="2">Concluido</option>
                        <option value="3">Cancelado</option>
                    }
                </select>
                <button type="submit" class="btn-buscar">
                    <i class="bi bi-search"></i> Buscar
                </button>
                @if (!string.IsNullOrEmpty(busqueda) || !string.IsNullOrEmpty(estadoQ))
                {
                    <a href="/Reserva/Index" class="btn-limpiar">
                        <i class="bi bi-x"></i> Limpiar
                    </a>
                }
            </form>
            <button class="btn-nuevo" onclick="abrirModalNueva()">
                <i class="bi bi-plus-lg"></i> Nueva Reserva
            </button>
        </div>

        <!-- GRILLA -->
        <div class="grilla">
            @if (!Model.Any())
            {
                <div class="vacio">
                    <i class="bi bi-calendar-x"></i>
                    No hay reservas registradas.
                </div>
            }
            else
            {
                foreach (var r in Model)
                {
                    var estadoClass = r.Estado == 1 ? "badge-estado-1" :
                                     r.Estado == 2 ? "badge-estado-2" : "badge-estado-3";
                    var estadoTxt   = r.Estado == 1 ? "Pendiente" :
                                     r.Estado == 2 ? "Concluido" : "Cancelado";
                    var tipoClass   = r.TipoReserva == "Web" ? "badge-tipo-web" : "badge-tipo-directa";
                    var nombre      = !string.IsNullOrEmpty(r.NombreCliente) ? r.NombreCliente
                                    : r.cliente?.Nombres ?? r.usuario?.NombreUsuario ?? "—";

                    <div class="reserva-card">
                        <div class="card-top-reserva">
                            <div class="card-tipo-nombre">
                                <div style="font-size:10px; color:#9CA3AF; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:2px;">Reservado para</div>
                                <div class="card-nombre-reserva">@nombre</div>
                                <div class="card-badges-top">
                                    <span class="@tipoClass">@r.TipoReserva</span>
                                    <span class="@estadoClass">@estadoTxt</span>
                                </div>
                            </div>
                        </div>
                        <div class="card-body-reserva">
                            <div class="card-dato">
                                <i class="bi bi-calendar3"></i>
                                <span>@r.FechaReserva.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="card-dato">
                                <i class="bi bi-clock"></i>
                                <span>@r.HoraReserva.ToString(@"hh\:mm")</span>
                            </div>
                            <div class="card-dato">
                                <i class="bi bi-people"></i>
                                <span>@r.CantidadPersonas personas</span>
                            </div>
                            <div class="card-costo">
                                S/ @r.CostoTotal.ToString("0.00")
                                <span>/ total</span>
                            </div>
                        </div>
                        <div class="card-footer-reserva">
                            <button class="btn-icono btn-detalle" title="Ver detalle"
                                    onclick="abrirDetalle(@r.IdReserva)">
                                <i class="bi bi-eye"></i>
                            </button>
                            @if (r.Estado == 1)
                            {
                                <button class="btn-icono btn-cancelar-card" title="Cancelar reserva"
                                        onclick="confirmarCancelar(@r.IdReserva, '@nombre')">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <!-- PAGINACIÓN -->
        @if (paginas > 1)
        {
            <div class="paginacion">
                <a class="pag-btn @(paginaActual == 1 ? "disabled" : "")"
                   href="/Reserva/Index?page=@(paginaActual-1)&Busqueda=@busqueda&Estado=@estadoQ">
                    <i class="bi bi-chevron-left"></i>
                </a>
                @for (int i = 1; i <= paginas; i++)
                {
                    <a class="pag-btn @(i == paginaActual ? "activo" : "")"
                       href="/Reserva/Index?page=@i&Busqueda=@busqueda&Estado=@estadoQ">@i</a>
                }
                <a class="pag-btn @(paginaActual == paginas ? "disabled" : "")"
                   href="/Reserva/Index?page=@(paginaActual+1)&Busqueda=@busqueda&Estado=@estadoQ">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        }

    </div>
</main>

