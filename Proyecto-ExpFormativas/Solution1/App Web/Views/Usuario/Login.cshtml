@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>La Estancia — Acceso</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
            :root {
                --acento:  #C9A84C;
                --fondo:   #F4F5F7;
                --carbon:  #2C2C2C;
                --oscuro:  #1C1C1C;
                --borde:   #E5E7EB;
                --rojo:    #EF4444;
            }

            * { margin: 0; padding: 0; box-sizing: border-box; }

            body {
                font-family: 'Lato', sans-serif;
                background: var(--fondo);
                height: 100vh;
                display: flex;
                overflow: hidden;
            }

            /* LADO IZQUIERDO */
            .lado-izq {
                width: 45%;
                background: var(--oscuro);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                padding: 3rem;
                position: relative;
                overflow: hidden;
            }

            /* Círculos decorativos dorados */
            .lado-izq::before {
                content: '';
                position: absolute;
                width: 320px; height: 320px;
                border-radius: 50%;
                border: 1px solid rgba(201,168,76,0.12);
                top: -80px; left: -80px;
            }
            .lado-izq::after {
                content: '';
                position: absolute;
                width: 220px; height: 220px;
                border-radius: 50%;
                border: 1px solid rgba(201,168,76,0.08);
                bottom: -60px; right: -60px;
            }

            /* Círculo extra */
            .deco-circulo {
                position: absolute;
                width: 160px; height: 160px;
                border-radius: 50%;
                border: 1px solid rgba(201,168,76,0.06);
                bottom: 80px; left: -40px;
            }

            /* Línea dorada superior */
            .deco-linea {
                position: absolute;
                top: 0; left: 0; right: 0;
                height: 3px;
                background: linear-gradient(90deg, transparent, var(--acento), transparent);
            }

            .izq-contenido {
                position: relative; z-index: 1;
                text-align: center;
                display: flex; flex-direction: column;
                align-items: center; gap: 1.4rem;
            }

            .logo-icono {
                width: 64px; height: 64px; border-radius: 16px;
                background: rgba(201,168,76,0.12);
                border: 1px solid rgba(201,168,76,0.25);
                display: flex; align-items: center; justify-content: center;
                font-size: 28px; color: var(--acento);
            }

            .logo-nombre {
                font-size: 32px; font-weight: 700;
                color: var(--acento);
                letter-spacing: 0.04em;
            }

            .logo-sub {
                font-size: 11px; font-weight: 400;
                color: rgba(255,255,255,0.3);
                letter-spacing: 0.2em;
                text-transform: uppercase;
                margin-top: -0.8rem;
            }

            .separador {
                width: 40px; height: 1px;
                background: rgba(201,168,76,0.3);
            }

            .logo-frase {
                font-size: 13px; color: rgba(255,255,255,0.4);
                line-height: 1.6; max-width: 260px;
                font-weight: 300;
            }

            /* Tags decorativos */
            .deco-tags {
                display: flex; gap: 0.5rem; flex-wrap: wrap;
                justify-content: center; margin-top: 0.5rem;
            }
            .deco-tag {
                font-size: 10px; color: rgba(201,168,76,0.5);
                border: 1px solid rgba(201,168,76,0.15);
                padding: 3px 10px; border-radius: 20px;
                letter-spacing: 0.1em; text-transform: uppercase;
            }

            /* LADO DERECHO */
            .lado-der {
                flex: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 3rem;
                background: var(--fondo);
            }

            .form-wrap {
                width: 100%; max-width: 380px;
                display: flex; flex-direction: column; gap: 1.8rem;
            }

            .form-header { display: flex; flex-direction: column; gap: 4px; }
            .form-titulo {
                font-size: 22px; font-weight: 700; color: var(--carbon);
            }
            .form-sub { font-size: 13px; color: #9CA3AF; }

            .form-body { display: flex; flex-direction: column; gap: 1rem; }

            .campo-grupo { display: flex; flex-direction: column; gap: 5px; }
            .campo-label {
                font-size: 11px; text-transform: uppercase;
                letter-spacing: 0.1em; color: #9CA3AF; font-weight: 600;
            }
            .campo-input-wrap { position: relative; }
            .campo-input {
                width: 100%; border: 1px solid var(--borde);
                border-radius: 8px; padding: 0.65rem 0.9rem;
                font-family: 'Lato', sans-serif; font-size: 14px;
                color: var(--carbon); outline: none; background: #fff;
                transition: border-color 0.2s, box-shadow 0.2s;
            }
            .campo-input:focus {
                border-color: var(--carbon);
                box-shadow: 0 0 0 3px rgba(44,44,44,0.06);
            }

            .btn-ojo {
                position: absolute; right: 0.8rem; top: 50%;
                transform: translateY(-50%);
                background: none; border: none; cursor: pointer;
                color: #9CA3AF; font-size: 15px; padding: 0;
                transition: color 0.2s;
            }
            .btn-ojo:hover { color: var(--carbon); }

            .alerta {
                background: #FEF2F2; border-left: 3px solid var(--rojo);
                padding: 0.7rem 0.9rem; border-radius: 6px;
                font-size: 13px; color: var(--rojo);
                display: flex; align-items: center; gap: 6px;
            }

            .btn-ingresar {
                width: 100%; background: var(--carbon); color: #fff;
                border: none; border-radius: 8px;
                padding: 0.75rem 1rem; font-size: 14px; font-weight: 700;
                font-family: 'Lato', sans-serif; cursor: pointer;
                display: flex; align-items: center; justify-content: center; gap: 6px;
                transition: background 0.2s, transform 0.1s;
                letter-spacing: 0.03em;
            }
            .btn-ingresar:hover { background: #444; }
            .btn-ingresar:active { transform: scale(0.99); }

            .form-footer {
                text-align: center; font-size: 11px;
                color: rgba(44,44,44,0.25); letter-spacing: 0.05em;
            }
    </style>
</head>
<body>

    <!-- LADO IZQUIERDO -->
    <div class="lado-izq">
        <div class="deco-linea"></div>
        <div class="deco-circulo"></div>

        <div class="izq-contenido">
            <div class="logo-icono">
                <i class="bi bi-cup-hot-fill"></i>
            </div>
            <div>
                <div class="logo-nombre">La Estancia</div>
                <div class="logo-sub">Sistema interno</div>
            </div>
            <div class="separador"></div>
            <div class="logo-frase">
                Plataforma de gestión interna para el control de mesas, reservas, personal y operaciones del restaurante.
            </div>
            <div class="deco-tags">
                <span class="deco-tag">Mesas</span>
                <span class="deco-tag">Reservas</span>
                <span class="deco-tag">Platillos</span>
                <span class="deco-tag">Personal</span>
            </div>
        </div>
    </div>

    <!-- LADO DERECHO -->
    <div class="lado-der">
        <div class="form-wrap">

            <div class="form-header">
                <div class="form-titulo">Bienvenido de vuelta</div>
                <div class="form-sub">Ingresa tus credenciales para acceder al sistema</div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alerta">
                    <i class="bi bi-exclamation-circle"></i>
                    @ViewBag.Error
                </div>
            }

            <form method="post" action="/Usuario/Login" class="form-body">
                <div class="campo-grupo">
                    <label class="campo-label">Correo electrónico</label>
                    <div class="campo-input-wrap">
                        <input type="email" name="Email" class="campo-input"
                               placeholder="correo@estancia.com" autocomplete="email" />
                    </div>
                </div>

                <div class="campo-grupo">
                    <label class="campo-label">Contraseña</label>
                    <div class="campo-input-wrap">
                        <input type="password" name="Contraseña" id="inputPassword"
                               class="campo-input con-ojo"
                               placeholder="••••••••" autocomplete="current-password" />
                    </div>
                </div>

                <button type="submit" class="btn-ingresar">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Ingresar
                </button>
            </form>

            <div class="form-footer">
                La Estancia &copy; @DateTime.Now.Year — Solo personal autorizado
            </div>

        </div>
    </div>

</body>
</html>
